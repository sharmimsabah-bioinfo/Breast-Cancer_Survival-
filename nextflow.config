// nextflow.config
// Profiles: local (default), aws, gcp

profiles {

    local {
        process.executor = 'local'
        process.memory   = '4 GB'
        process.cpus     = 2
        docker.enabled   = false
    }

    aws {
        process.executor       = 'awsbatch'
        process.queue          = 'brca-pipeline-queue'
        aws.region             = 'us-east-1'
        aws.batch.cliPath      = '/usr/local/bin/aws'
        workDir                = 's3://your-bucket/nextflow-work'
        docker.enabled         = true
        aws.batch.spot         = true   // 70% cost reduction

        process {
            withLabel: 'gpu' {
                queue            = 'brca-gpu-queue'
                memory           = '32 GB'
                cpus             = 8
                accelerator      = 1
                containerOptions = '--gpus all'
            }
        }
    }

    gcp {
        process.executor   = 'google-lifesciences'
        google.location    = 'us-east1'
        google.project     = 'your-gcp-project'
        workDir            = 'gs://your-bucket/nextflow-work'
        docker.enabled     = true
    }
}

process.container      = 'your-username/brca-pipeline:latest'
process.errorStrategy  = 'retry'
process.maxRetries     = 2
docker.runOptions      = '--rm'
